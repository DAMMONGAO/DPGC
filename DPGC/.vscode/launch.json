{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python 调试程序: demo.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/demo.py",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "justMyCode": false,
            "args": [
                "--calib=calib/iphone.txt --stride=5",
                "--plot",
                "--imagedir=/home/ghb/DPVO/test1.mp4"
            ]
        },
        {
            "name": "Python: train_single_gpu.py",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/train_single_gpu.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [
                "--steps=240000",
                "--lr=0.00008",
                "--name=gao"
            ]
        },
        {
            "name": "Python 调试程序: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}